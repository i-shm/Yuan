  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#346270"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#006F78"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#3C678F"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#635A93"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.selector"
      ],
      "settings": {
        "foreground": "#006A94"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#006F78"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.scss"
      ],
      "settings": {
        "foreground": "#516BA0"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#9C4343"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#006F78"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#006A94"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#635A93"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#9C4343"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#346270"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#516BA0"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#346270"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#3C678F"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#006F78"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#006A94"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#006A94"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#006A94"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#3C678F"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7B766A"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#516BA0"
      }
    },
    {
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#006F78"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#42516A"
      }
    },
    {
      "scope": [
        "variable.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#006A94"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#42516A"
      }
    },
    {
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#516BA0"
      }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#006A94"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#006F78"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#006F78",
    "type": "#006F78",
    "class": "#006F78",
    "enum": "#006F78",
    "interface": "#006F78",
    "struct": "#006F78",
    "typeParameter": "#635A93",
    "parameter": "#42516A",
    "variable": "#42516A",
    "property": "#42516A",
    "enumMember": "#3C678F",
    "event": "#516BA0",
    "function": "#516BA0",
    "method": "#516BA0",
    "macro": "#516BA0",
    "keyword": "#006A94",
    "comment": "#346270",
    "string": "#3C678F",
    "number": "#3C678F",
    "regexp": "#635A93",
    "operator": "#2F2B26",
    "decorator": "#635A93",
    "newOperator": "#006A94",
    "stringLiteral": "#3C678F",
    "customLiteral": "#3C678F",
    "numberLiteral": "#3C678F"
  }
}
