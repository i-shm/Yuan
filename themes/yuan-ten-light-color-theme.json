  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#5D6232"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#00755F"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#076C92"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#90502A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.selector"
      ],
      "settings": {
        "foreground": "#924667"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#00755F"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.scss"
      ],
      "settings": {
        "foreground": "#6467A8"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#9C4343"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#00755F"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#924667"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#90502A"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#9C4343"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#5D6232"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#6467A8"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#5D6232"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#076C92"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#00755F"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#924667"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#00755F"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#924667"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#076C92"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7B766A"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#6467A8"
      }
    },
    {
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#00755F"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#42516A"
      }
    },
    {
      "scope": [
        "variable.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#924667"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#42516A"
      }
    },
    {
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#6467A8"
      }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#924667"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#00755F"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#00755F",
    "type": "#00755F",
    "class": "#00755F",
    "enum": "#00755F",
    "interface": "#00755F",
    "struct": "#00755F",
    "typeParameter": "#90502A",
    "parameter": "#42516A",
    "variable": "#42516A",
    "property": "#42516A",
    "enumMember": "#076C92",
    "event": "#6467A8",
    "function": "#6467A8",
    "method": "#6467A8",
    "macro": "#6467A8",
    "keyword": "#924667",
    "comment": "#5D6232",
    "string": "#076C92",
    "number": "#076C92",
    "regexp": "#90502A",
    "operator": "#2F2B26",
    "decorator": "#90502A",
    "newOperator": "#924667",
    "stringLiteral": "#076C92",
    "customLiteral": "#076C92",
    "numberLiteral": "#076C92"
  }
}
