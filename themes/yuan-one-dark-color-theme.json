  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#B1A47D"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#D0A66C"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#AEBC82"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#7BC39F"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.selector"
      ],
      "settings": {
        "foreground": "#B7AE56"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#D0A66C"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.scss"
      ],
      "settings": {
        "foreground": "#9FC58A"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#D0A66C"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#B7AE56"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#7BC39F"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#B1A47D"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#9FC58A"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#B1A47D"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#AEBC82"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#D0A66C"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#B7AE56"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#B7AE56"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#B7AE56"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#AEBC82"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A867C"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#9FC58A"
      }
    },
    {
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#D0A66C"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "variable.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#B7AE56"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#9FC58A"
      }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#B7AE56"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#D0A66C"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#D0A66C",
    "type": "#D0A66C",
    "class": "#D0A66C",
    "enum": "#D0A66C",
    "interface": "#D0A66C",
    "struct": "#D0A66C",
    "typeParameter": "#7BC39F",
    "parameter": "#C6D6DE",
    "variable": "#C6D6DE",
    "property": "#C6D6DE",
    "enumMember": "#AEBC82",
    "event": "#9FC58A",
    "function": "#9FC58A",
    "method": "#9FC58A",
    "macro": "#9FC58A",
    "keyword": "#B7AE56",
    "comment": "#B1A47D",
    "string": "#AEBC82",
    "number": "#AEBC82",
    "regexp": "#7BC39F",
    "operator": "#D8D2C4",
    "decorator": "#7BC39F",
    "newOperator": "#B7AE56",
    "stringLiteral": "#AEBC82",
    "customLiteral": "#AEBC82",
    "numberLiteral": "#AEBC82"
  }
}
