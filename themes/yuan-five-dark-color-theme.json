  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#9FA1C7"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#93ADE8"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#C4A6DB"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#DE99B7"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.selector"
      ],
      "settings": {
        "foreground": "#AE9DEA"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#93ADE8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.scss"
      ],
      "settings": {
        "foreground": "#D6A4D7"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#93ADE8"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#AE9DEA"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#DE99B7"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#9FA1C7"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#D6A4D7"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#9FA1C7"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#C4A6DB"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#93ADE8"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#AE9DEA"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#AE9DEA"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#AE9DEA"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#C4A6DB"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A867C"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#D6A4D7"
      }
    },
    {
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#93ADE8"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "variable.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#AE9DEA"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#D6A4D7"
      }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#AE9DEA"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#93ADE8"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#93ADE8",
    "type": "#93ADE8",
    "class": "#93ADE8",
    "enum": "#93ADE8",
    "interface": "#93ADE8",
    "struct": "#93ADE8",
    "typeParameter": "#DE99B7",
    "parameter": "#C6D6DE",
    "variable": "#C6D6DE",
    "property": "#C6D6DE",
    "enumMember": "#C4A6DB",
    "event": "#D6A4D7",
    "function": "#D6A4D7",
    "method": "#D6A4D7",
    "macro": "#D6A4D7",
    "keyword": "#AE9DEA",
    "comment": "#9FA1C7",
    "string": "#C4A6DB",
    "number": "#C4A6DB",
    "regexp": "#DE99B7",
    "operator": "#D8D2C4",
    "decorator": "#DE99B7",
    "newOperator": "#AE9DEA",
    "stringLiteral": "#C4A6DB",
    "customLiteral": "#C4A6DB",
    "numberLiteral": "#C4A6DB"
  }
}
