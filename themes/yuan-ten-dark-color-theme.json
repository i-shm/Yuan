  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#7EADBD"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#61BFC8"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#8CB9E5"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#B0A8E7"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.selector"
      ],
      "settings": {
        "foreground": "#59B7E4"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#61BFC8"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.scss"
      ],
      "settings": {
        "foreground": "#9AB7F2"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#61BFC8"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#59B7E4"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#B0A8E7"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#7EADBD"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#9AB7F2"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#7EADBD"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#8CB9E5"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#61BFC8"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#59B7E4"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#59B7E4"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#59B7E4"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#8CB9E5"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A867C"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#9AB7F2"
      }
    },
    {
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#61BFC8"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "variable.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#59B7E4"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#9AB7F2"
      }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#59B7E4"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#61BFC8"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#61BFC8",
    "type": "#61BFC8",
    "class": "#61BFC8",
    "enum": "#61BFC8",
    "interface": "#61BFC8",
    "struct": "#61BFC8",
    "typeParameter": "#B0A8E7",
    "parameter": "#C6D6DE",
    "variable": "#C6D6DE",
    "property": "#C6D6DE",
    "enumMember": "#8CB9E5",
    "event": "#9AB7F2",
    "function": "#9AB7F2",
    "method": "#9AB7F2",
    "macro": "#9AB7F2",
    "keyword": "#59B7E4",
    "comment": "#7EADBD",
    "string": "#8CB9E5",
    "number": "#8CB9E5",
    "regexp": "#B0A8E7",
    "operator": "#D8D2C4",
    "decorator": "#B0A8E7",
    "newOperator": "#59B7E4",
    "stringLiteral": "#8CB9E5",
    "customLiteral": "#8CB9E5",
    "numberLiteral": "#8CB9E5"
  }
}
