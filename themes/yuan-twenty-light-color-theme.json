  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#765043"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#8C4A47"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#815A2D"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#666723"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.selector"
      ],
      "settings": {
        "foreground": "#904C1B"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#8C4A47"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.scss"
      ],
      "settings": {
        "foreground": "#846726"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#9C4343"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#8C4A47"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#904C1B"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#666723"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#9C4343"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#765043"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#846726"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#765043"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#815A2D"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#8C4A47"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#904C1B"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#904C1B"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#904C1B"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#815A2D"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7B766A"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#846726"
      }
    },
    {
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#8C4A47"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#42516A"
      }
    },
    {
      "scope": [
        "variable.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#904C1B"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#42516A"
      }
    },
    {
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#846726"
      }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#904C1B"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#8C4A47"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#8C4A47",
    "type": "#8C4A47",
    "class": "#8C4A47",
    "enum": "#8C4A47",
    "interface": "#8C4A47",
    "struct": "#8C4A47",
    "typeParameter": "#666723",
    "parameter": "#42516A",
    "variable": "#42516A",
    "property": "#42516A",
    "enumMember": "#815A2D",
    "event": "#846726",
    "function": "#846726",
    "method": "#846726",
    "macro": "#846726",
    "keyword": "#904C1B",
    "comment": "#765043",
    "string": "#815A2D",
    "number": "#815A2D",
    "regexp": "#666723",
    "operator": "#2F2B26",
    "decorator": "#666723",
    "newOperator": "#904C1B",
    "stringLiteral": "#815A2D",
    "customLiteral": "#815A2D",
    "numberLiteral": "#815A2D"
  }
}
