  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#C49A8B"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#E19892"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#D7AB7D"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#B4B672"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.selector"
      ],
      "settings": {
        "foreground": "#E29668"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#E19892"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.scss"
      ],
      "settings": {
        "foreground": "#D3B373"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#E19892"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#E29668"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#B4B672"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#C49A8B"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#D3B373"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#C49A8B"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#D7AB7D"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#E19892"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#E29668"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#E29668"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#E29668"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#D7AB7D"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A867C"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#D3B373"
      }
    },
    {
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#E19892"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "variable.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#E29668"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#D3B373"
      }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#E29668"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#E19892"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#E19892",
    "type": "#E19892",
    "class": "#E19892",
    "enum": "#E19892",
    "interface": "#E19892",
    "struct": "#E19892",
    "typeParameter": "#B4B672",
    "parameter": "#C6D6DE",
    "variable": "#C6D6DE",
    "property": "#C6D6DE",
    "enumMember": "#D7AB7D",
    "event": "#D3B373",
    "function": "#D3B373",
    "method": "#D3B373",
    "macro": "#D3B373",
    "keyword": "#E29668",
    "comment": "#C49A8B",
    "string": "#D7AB7D",
    "number": "#D7AB7D",
    "regexp": "#B4B672",
    "operator": "#D8D2C4",
    "decorator": "#B4B672",
    "newOperator": "#E29668",
    "stringLiteral": "#D7AB7D",
    "customLiteral": "#D7AB7D",
    "numberLiteral": "#D7AB7D"
  }
}
