  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#AAA0D0"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#E496B5"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#E49F75"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#68BDE4"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.selector"
      ],
      "settings": {
        "foreground": "#4FBEA2"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#E496B5"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.scss"
      ],
      "settings": {
        "foreground": "#C6B96B"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#E496B5"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#4FBEA2"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#68BDE4"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#AAA0D0"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#C6B96B"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#AAA0D0"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#E49F75"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#E496B5"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#4FBEA2"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#E496B5"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#4FBEA2"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#E49F75"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A867C"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#C6B96B"
      }
    },
    {
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#E496B5"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "variable.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#4FBEA2"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#C6B96B"
      }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#4FBEA2"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#E496B5"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#E496B5",
    "type": "#E496B5",
    "class": "#E496B5",
    "enum": "#E496B5",
    "interface": "#E496B5",
    "struct": "#E496B5",
    "typeParameter": "#68BDE4",
    "parameter": "#C6D6DE",
    "variable": "#C6D6DE",
    "property": "#C6D6DE",
    "enumMember": "#E49F75",
    "event": "#C6B96B",
    "function": "#C6B96B",
    "method": "#C6B96B",
    "macro": "#C6B96B",
    "keyword": "#4FBEA2",
    "comment": "#AAA0D0",
    "string": "#E49F75",
    "number": "#E49F75",
    "regexp": "#68BDE4",
    "operator": "#D8D2C4",
    "decorator": "#68BDE4",
    "newOperator": "#4FBEA2",
    "stringLiteral": "#E49F75",
    "customLiteral": "#E49F75",
    "numberLiteral": "#E49F75"
  }
}
