  "tokenColors": [
    {
      "scope": ["meta.embedded", "source.groovy.embedded", "string meta.image.inline.markdown", "variable.legacy.builtin.python"],
      "settings": { "foreground": "#2F2B26" }
    },
    { "scope": "emphasis", "settings": { "fontStyle": "italic" } },
    { "scope": "strong", "settings": { "fontStyle": "bold" } },
    { "scope": "comment", "settings": { "foreground": "#788B45" } },
    { "scope": "constant.language", "settings": { "foreground": "#2F6F9F" } },
    {
      "scope": ["constant.numeric", "variable.other.enummember", "keyword.operator.plus.exponent", "keyword.operator.minus.exponent"],
      "settings": { "foreground": "#3B8F74" }
    },
    { "scope": "constant.regexp", "settings": { "foreground": "#7A5AA6" } },
    { "scope": ["entity.name.tag", "entity.name.selector"], "settings": { "foreground": "#B8323B" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#2F6F9F" } },
    {
      "scope": ["entity.other.attribute-name.class.css", "source.css entity.other.attribute-name.class", "entity.other.attribute-name.id.css", "source.css entity.other.attribute-name.pseudo-class", "entity.other.attribute-name.scss"],
      "settings": { "foreground": "#A66A3A" }
    },
    { "scope": "invalid", "settings": { "foreground": "#B8323B" } },
    { "scope": "markup.underline", "settings": { "fontStyle": "underline" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold", "foreground": "#2F6F9F" } },
    { "scope": "markup.heading", "settings": { "fontStyle": "bold", "foreground": "#B8323B" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic", "foreground": "#7A5AA6" } },
    { "scope": "markup.strikethrough", "settings": { "fontStyle": "strikethrough" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#788B45" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#B8323B" } },
    { "scope": "markup.changed", "settings": { "foreground": "#2F6F9F" } },
    { "scope": ["punctuation.definition.quote.begin.markdown", "punctuation.definition.list.begin.markdown"], "settings": { "foreground": "#A66A3A" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#A66A3A" } },
    { "scope": "punctuation.definition.tag", "settings": { "foreground": "#8A2F36" } },
    { "scope": ["meta.preprocessor", "entity.name.function.preprocessor"], "settings": { "foreground": "#2F6F9F" } },
    { "scope": "meta.preprocessor.string", "settings": { "foreground": "#3B8F74" } },
    { "scope": "meta.preprocessor.numeric", "settings": { "foreground": "#A66A3A" } },
    { "scope": "meta.structure.dictionary.key.python", "settings": { "foreground": "#2F6F9F" } },
    { "scope": ["storage", "storage.type", "storage.modifier"], "settings": { "foreground": "#B8323B" } },
    { "scope": ["string", "meta.embedded.assembly"], "settings": { "foreground": "#3B8F74" } },
    { "scope": ["string.comment.buffered.block.pug", "string.quoted.pug", "string.interpolated.pug", "string.unquoted.plain.in.yaml", "string.quoted.double.xml", "string.quoted.single.xml", "string.quoted.double.html", "string.quoted.single.html"], "settings": { "foreground": "#2F6F9F" } },
    { "scope": "string.regexp", "settings": { "foreground": "#7A5AA6" } },
    { "scope": ["punctuation.definition.template-expression.begin", "punctuation.definition.template-expression.end", "punctuation.section.embedded"], "settings": { "foreground": "#B8323B" } },
    { "scope": "meta.template.expression", "settings": { "foreground": "#2F2B26" } },
    { "scope": ["support.constant.property-value", "support.constant.font-name", "support.constant.media-type", "constant.other.color.rgb-value", "support.constant.color"], "settings": { "foreground": "#2F6F9F" } },
    { "scope": ["support.type.vendored.property-name", "support.type.property-name", "source.css variable"], "settings": { "foreground": "#B8323B" } },
    { "scope": "support.type.property-name.json", "settings": { "foreground": "#2F6F9F" } },
    { "scope": ["keyword", "keyword.control"], "settings": { "foreground": "#B8323B" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#4E483E" } },
    { "scope": ["keyword.operator.new", "keyword.operator.expression", "keyword.operator.cast", "keyword.operator.wordlike"], "settings": { "foreground": "#B8323B" } },
    { "scope": "keyword.other.unit", "settings": { "foreground": "#3B8F74" } },
    { "scope": ["punctuation.section.embedded.begin.php", "punctuation.section.embedded.end.php"], "settings": { "foreground": "#B8323B" } },
    { "scope": "support.function.git-rebase", "settings": { "foreground": "#2F6F9F" } },
    { "scope": "constant.sha.git-rebase", "settings": { "foreground": "#3B8F74" } },
    { "scope": ["storage.modifier.import.java", "variable.language.wildcard.java", "storage.modifier.package.java"], "settings": { "foreground": "#2F2B26" } },
    { "scope": "variable.language", "settings": { "foreground": "#B8323B" } },
    { "name": "Function declarations", "scope": ["entity.name.function", "support.function", "support.constant.handlebars", "source.powershell variable.other.member", "entity.name.operator.custom-literal"], "settings": { "foreground": "#A66A3A" } },
    { "name": "Types declaration and references", "scope": ["support.class", "support.type", "entity.name.type", "entity.name.namespace", "entity.other.attribute", "entity.name.scope-resolution", "entity.name.class", "storage.type.cs", "storage.type.java", "storage.type.groovy"], "settings": { "foreground": "#2F6F9F" } },
    { "name": "Control flow / Special keywords", "scope": ["source.cpp keyword.operator.new", "source.cpp keyword.operator.delete", "keyword.other.using", "keyword.other.directive.using", "keyword.other.operator", "entity.name.operator"], "settings": { "foreground": "#7A5AA6" } },
    { "name": "Variable and parameter name", "scope": ["variable", "meta.definition.variable.name", "support.variable", "entity.name.variable", "constant.other.placeholder"], "settings": { "foreground": "#42516A" } },
    { "name": "Constants and enums", "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#2F6F9F" } },
    { "name": "Object keys", "scope": ["meta.object-literal.key"], "settings": { "foreground": "#42516A" } },
    { "name": "Regular expression groups", "scope": ["punctuation.definition.group.regexp", "punctuation.definition.character-class.regexp", "keyword.operator.negation.regexp", "support.other.parenthesis.regexp"], "settings": { "foreground": "#A66A3A" } },
    { "scope": ["constant.character.character-class.regexp", "constant.other.character-class.set.regexp", "constant.other.character-class.regexp", "constant.character.set.regexp"], "settings": { "foreground": "#B8323B" } },
    { "scope": "keyword.operator.quantifier.regexp", "settings": { "foreground": "#4E483E" } },
    { "scope": ["keyword.operator.or.regexp", "keyword.control.anchor.regexp"], "settings": { "foreground": "#B8323B" } },
    { "scope": ["constant.character", "constant.other.option"], "settings": { "foreground": "#2F6F9F" } },
    { "scope": "constant.character.escape", "settings": { "foreground": "#B8323B" } },
    { "scope": "entity.name.label", "settings": { "foreground": "#2F2B26" } }
  ],
  "semanticTokenColors": {
    "namespace": "#2F6F9F",
    "type": "#2F6F9F",
    "class": "#2F6F9F",
    "enum": "#2F6F9F",
    "interface": "#2F6F9F",
    "struct": "#2F6F9F",
    "typeParameter": "#7A5AA6",
    "parameter": "#42516A",
    "variable": "#42516A",
    "property": "#42516A",
    "enumMember": "#2F6F9F",
    "event": "#A66A3A",
    "function": "#A66A3A",
    "method": "#A66A3A",
    "macro": "#7A5AA6",
    "keyword": "#B8323B",
    "comment": "#788B45",
    "string": "#3B8F74",
    "number": "#3B8F74",
    "regexp": "#7A5AA6",
    "operator": "#4E483E",
    "decorator": "#A66A3A",
    "newOperator": "#7A5AA6",
    "stringLiteral": "#3B8F74",
    "customLiteral": "#A66A3A",
    "numberLiteral": "#3B8F74"
  }
}
