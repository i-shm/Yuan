  "tokenColors": [
    {
      "scope": ["meta.embedded", "source.groovy.embedded", "string meta.image.inline.markdown", "variable.legacy.builtin.python"],
      "settings": { "foreground": "#D8D2C4" }
    },
    { "scope": "emphasis", "settings": { "fontStyle": "italic" } },
    { "scope": "strong", "settings": { "fontStyle": "bold" } },
    { "scope": "comment", "settings": { "foreground": "#A6B875" } },
    { "scope": "constant.language", "settings": { "foreground": "#78A8C8" } },
    {
      "scope": ["constant.numeric", "variable.other.enummember", "keyword.operator.plus.exponent", "keyword.operator.minus.exponent"],
      "settings": { "foreground": "#68B09A" }
    },
    { "scope": "constant.regexp", "settings": { "foreground": "#B59ADA" } },
    { "scope": ["entity.name.tag", "entity.name.selector"], "settings": { "foreground": "#E06C75" } },
    { "scope": "entity.other.attribute-name", "settings": { "foreground": "#78A8C8" } },
    {
      "scope": ["entity.other.attribute-name.class.css", "source.css entity.other.attribute-name.class", "entity.other.attribute-name.id.css", "source.css entity.other.attribute-name.pseudo-class", "entity.other.attribute-name.scss"],
      "settings": { "foreground": "#D2A76F" }
    },
    { "scope": "invalid", "settings": { "foreground": "#F0848C" } },
    { "scope": "markup.underline", "settings": { "fontStyle": "underline" } },
    { "scope": "markup.bold", "settings": { "fontStyle": "bold", "foreground": "#78A8C8" } },
    { "scope": "markup.heading", "settings": { "fontStyle": "bold", "foreground": "#E06C75" } },
    { "scope": "markup.italic", "settings": { "fontStyle": "italic", "foreground": "#B59ADA" } },
    { "scope": "markup.strikethrough", "settings": { "fontStyle": "strikethrough" } },
    { "scope": "markup.inserted", "settings": { "foreground": "#A6B875" } },
    { "scope": "markup.deleted", "settings": { "foreground": "#E06C75" } },
    { "scope": "markup.changed", "settings": { "foreground": "#78A8C8" } },
    { "scope": ["punctuation.definition.quote.begin.markdown", "punctuation.definition.list.begin.markdown"], "settings": { "foreground": "#D2A76F" } },
    { "scope": "markup.inline.raw", "settings": { "foreground": "#D2A76F" } },
    { "scope": "punctuation.definition.tag", "settings": { "foreground": "#C5676F" } },
    { "scope": ["meta.preprocessor", "entity.name.function.preprocessor"], "settings": { "foreground": "#78A8C8" } },
    { "scope": "meta.preprocessor.string", "settings": { "foreground": "#68B09A" } },
    { "scope": "meta.preprocessor.numeric", "settings": { "foreground": "#D2A76F" } },
    { "scope": "meta.structure.dictionary.key.python", "settings": { "foreground": "#78A8C8" } },
    { "scope": ["storage", "storage.type", "storage.modifier"], "settings": { "foreground": "#E06C75" } },
    { "scope": ["string", "meta.embedded.assembly"], "settings": { "foreground": "#68B09A" } },
    { "scope": ["string.comment.buffered.block.pug", "string.quoted.pug", "string.interpolated.pug", "string.unquoted.plain.in.yaml", "string.quoted.double.xml", "string.quoted.single.xml", "string.quoted.double.html", "string.quoted.single.html"], "settings": { "foreground": "#78A8C8" } },
    { "scope": "string.regexp", "settings": { "foreground": "#B59ADA" } },
    { "scope": ["punctuation.definition.template-expression.begin", "punctuation.definition.template-expression.end", "punctuation.section.embedded"], "settings": { "foreground": "#E06C75" } },
    { "scope": "meta.template.expression", "settings": { "foreground": "#D8D2C4" } },
    { "scope": ["support.constant.property-value", "support.constant.font-name", "support.constant.media-type", "constant.other.color.rgb-value", "support.constant.color"], "settings": { "foreground": "#78A8C8" } },
    { "scope": ["support.type.vendored.property-name", "support.type.property-name", "source.css variable"], "settings": { "foreground": "#E06C75" } },
    { "scope": "support.type.property-name.json", "settings": { "foreground": "#78A8C8" } },
    { "scope": ["keyword", "keyword.control"], "settings": { "foreground": "#E06C75" } },
    { "scope": "keyword.operator", "settings": { "foreground": "#D8D2C4" } },
    { "scope": ["keyword.operator.new", "keyword.operator.expression", "keyword.operator.cast", "keyword.operator.wordlike"], "settings": { "foreground": "#E06C75" } },
    { "scope": "keyword.other.unit", "settings": { "foreground": "#68B09A" } },
    { "scope": ["punctuation.section.embedded.begin.php", "punctuation.section.embedded.end.php"], "settings": { "foreground": "#E06C75" } },
    { "scope": "support.function.git-rebase", "settings": { "foreground": "#78A8C8" } },
    { "scope": "constant.sha.git-rebase", "settings": { "foreground": "#68B09A" } },
    { "scope": ["storage.modifier.import.java", "variable.language.wildcard.java", "storage.modifier.package.java"], "settings": { "foreground": "#D8D2C4" } },
    { "scope": "variable.language", "settings": { "foreground": "#E06C75" } },
    { "name": "Function declarations", "scope": ["entity.name.function", "support.function", "support.constant.handlebars", "source.powershell variable.other.member", "entity.name.operator.custom-literal"], "settings": { "foreground": "#D2A76F" } },
    { "name": "Types declaration and references", "scope": ["support.class", "support.type", "entity.name.type", "entity.name.namespace", "entity.other.attribute", "entity.name.scope-resolution", "entity.name.class", "storage.type.cs", "storage.type.java", "storage.type.groovy"], "settings": { "foreground": "#78A8C8" } },
    { "name": "Control flow / Special keywords", "scope": ["source.cpp keyword.operator.new", "source.cpp keyword.operator.delete", "keyword.other.using", "keyword.other.directive.using", "keyword.other.operator", "entity.name.operator"], "settings": { "foreground": "#B59ADA" } },
    { "name": "Variable and parameter name", "scope": ["variable", "meta.definition.variable.name", "support.variable", "entity.name.variable", "constant.other.placeholder"], "settings": { "foreground": "#C6D6DE" } },
    { "name": "Constants and enums", "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#78A8C8" } },
    { "name": "Object keys", "scope": ["meta.object-literal.key"], "settings": { "foreground": "#C6D6DE" } },
    { "name": "Regular expression groups", "scope": ["punctuation.definition.group.regexp", "punctuation.definition.character-class.regexp", "keyword.operator.negation.regexp", "support.other.parenthesis.regexp"], "settings": { "foreground": "#D2A76F" } },
    { "scope": ["constant.character.character-class.regexp", "constant.other.character-class.set.regexp", "constant.other.character-class.regexp", "constant.character.set.regexp"], "settings": { "foreground": "#E06C75" } },
    { "scope": "keyword.operator.quantifier.regexp", "settings": { "foreground": "#D8D2C4" } },
    { "scope": ["keyword.operator.or.regexp", "keyword.control.anchor.regexp"], "settings": { "foreground": "#E06C75" } },
    { "scope": ["constant.character", "constant.other.option"], "settings": { "foreground": "#78A8C8" } },
    { "scope": "constant.character.escape", "settings": { "foreground": "#E06C75" } },
    { "scope": "entity.name.label", "settings": { "foreground": "#D8D2C4" } }
  ],
  "semanticTokenColors": {
    "namespace": "#78A8C8",
    "type": "#78A8C8",
    "class": "#78A8C8",
    "enum": "#78A8C8",
    "interface": "#78A8C8",
    "struct": "#78A8C8",
    "typeParameter": "#B59ADA",
    "parameter": "#C6D6DE",
    "variable": "#C6D6DE",
    "property": "#C6D6DE",
    "enumMember": "#78A8C8",
    "event": "#D2A76F",
    "function": "#D2A76F",
    "method": "#D2A76F",
    "macro": "#B59ADA",
    "keyword": "#E06C75",
    "comment": "#A6B875",
    "string": "#68B09A",
    "number": "#68B09A",
    "regexp": "#B59ADA",
    "operator": "#D8D2C4",
    "decorator": "#D2A76F",
    "newOperator": "#B59ADA",
    "stringLiteral": "#68B09A",
    "customLiteral": "#D2A76F",
    "numberLiteral": "#68B09A"
  }
}
