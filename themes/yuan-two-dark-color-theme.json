  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#84B09D"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#84BE90"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#73C5C3"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#77BAE3"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.selector"
      ],
      "settings": {
        "foreground": "#4DC1AB"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#84BE90"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.scss"
      ],
      "settings": {
        "foreground": "#6CC7D7"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#84BE90"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#4DC1AB"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#77BAE3"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#84B09D"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#6CC7D7"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#84B09D"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#73C5C3"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#84BE90"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#4DC1AB"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#4DC1AB"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#4DC1AB"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#73C5C3"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A867C"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#6CC7D7"
      }
    },
    {
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#84BE90"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "variable.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#4DC1AB"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#6CC7D7"
      }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#4DC1AB"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#84BE90"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#84BE90",
    "type": "#84BE90",
    "class": "#84BE90",
    "enum": "#84BE90",
    "interface": "#84BE90",
    "struct": "#84BE90",
    "typeParameter": "#77BAE3",
    "parameter": "#C6D6DE",
    "variable": "#C6D6DE",
    "property": "#C6D6DE",
    "enumMember": "#73C5C3",
    "event": "#6CC7D7",
    "function": "#6CC7D7",
    "method": "#6CC7D7",
    "macro": "#6CC7D7",
    "keyword": "#4DC1AB",
    "comment": "#84B09D",
    "string": "#73C5C3",
    "number": "#73C5C3",
    "regexp": "#77BAE3",
    "operator": "#D8D2C4",
    "decorator": "#77BAE3",
    "newOperator": "#4DC1AB",
    "stringLiteral": "#73C5C3",
    "customLiteral": "#73C5C3",
    "numberLiteral": "#73C5C3"
  }
}
