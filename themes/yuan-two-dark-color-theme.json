  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#C99E7B"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#A9BB71"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#61C6B1"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#E496B3"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.selector"
      ],
      "settings": {
        "foreground": "#B298E3"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#A9BB71"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.scss"
      ],
      "settings": {
        "foreground": "#6BC5E8"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#A9BB71"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#B298E3"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#E496B3"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#ED8B88"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#C99E7B"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#6BC5E8"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#C99E7B"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#61C6B1"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#A9BB71"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#B298E3"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#A9BB71"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#B298E3"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#61C6B1"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8A867C"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#6BC5E8"
      }
    },
    {
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#A9BB71"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "variable.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#B298E3"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#C6D6DE"
      }
    },
    {
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#6BC5E8"
      }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#B298E3"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#D8D2C4"
      }
    },
    {
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#A9BB71"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#A9BB71",
    "type": "#A9BB71",
    "class": "#A9BB71",
    "enum": "#A9BB71",
    "interface": "#A9BB71",
    "struct": "#A9BB71",
    "typeParameter": "#E496B3",
    "parameter": "#C6D6DE",
    "variable": "#C6D6DE",
    "property": "#C6D6DE",
    "enumMember": "#61C6B1",
    "event": "#6BC5E8",
    "function": "#6BC5E8",
    "method": "#6BC5E8",
    "macro": "#6BC5E8",
    "keyword": "#B298E3",
    "comment": "#C99E7B",
    "string": "#61C6B1",
    "number": "#61C6B1",
    "regexp": "#E496B3",
    "operator": "#D8D2C4",
    "decorator": "#E496B3",
    "newOperator": "#B298E3",
    "stringLiteral": "#61C6B1",
    "customLiteral": "#61C6B1",
    "numberLiteral": "#61C6B1"
  }
}
