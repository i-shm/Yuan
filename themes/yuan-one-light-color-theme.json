  "tokenColors": [
    {
      "scope": [
        "meta.embedded",
        "source.groovy.embedded",
        "string meta.image.inline.markdown",
        "variable.legacy.builtin.python"
      ],
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": "emphasis",
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": "strong",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "scope": "comment",
      "settings": {
        "foreground": "#665A36"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#7E581B"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "variable.other.enummember",
        "keyword.operator.plus.exponent",
        "keyword.operator.minus.exponent"
      ],
      "settings": {
        "foreground": "#5E6A32"
      }
    },
    {
      "scope": "constant.regexp",
      "settings": {
        "foreground": "#2A7352"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.selector"
      ],
      "settings": {
        "foreground": "#6C6200"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#7E581B"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name.class.css",
        "source.css entity.other.attribute-name.class",
        "entity.other.attribute-name.id.css",
        "source.css entity.other.attribute-name.pseudo-class",
        "entity.other.attribute-name.scss"
      ],
      "settings": {
        "foreground": "#557741"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#9C4343"
      }
    },
    {
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#7E581B"
      }
    },
    {
      "scope": "markup.heading",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#6C6200"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#2A7352"
      }
    },
    {
      "scope": "markup.strikethrough",
      "settings": {
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#9C4343"
      }
    },
    {
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#665A36"
      }
    },
    {
      "scope": "markup.changed",
      "settings": {
        "foreground": "#557741"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#665A36"
      }
    },
    {
      "scope": "markup.inline.raw",
      "settings": {
        "foreground": "#5E6A32"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#7E581B"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#6C6200"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#6C6200"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#6C6200"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#5E6A32"
      }
    },
    {
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7B766A"
      }
    },
    {
      "scope": [
        "support.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#557741"
      }
    },
    {
      "scope": [
        "support.class",
        "support.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace"
      ],
      "settings": {
        "foreground": "#7E581B"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable",
        "entity.name.variable",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#42516A"
      }
    },
    {
      "scope": [
        "variable.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#6C6200"
      }
    },
    {
      "scope": [
        "meta.object-literal.key",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#42516A"
      }
    },
    {
      "scope": [
        "punctuation.definition.group.regexp",
        "punctuation.definition.character-class.regexp",
        "keyword.operator.negation.regexp",
        "support.other.parenthesis.regexp"
      ],
      "settings": {
        "foreground": "#557741"
      }
    },
    {
      "scope": [
        "constant.character.character-class.regexp",
        "keyword.operator.or.regexp",
        "keyword.control.anchor.regexp"
      ],
      "settings": {
        "foreground": "#6C6200"
      }
    },
    {
      "scope": "keyword.operator.quantifier.regexp",
      "settings": {
        "foreground": "#2F2B26"
      }
    },
    {
      "scope": [
        "constant.character",
        "constant.other.option"
      ],
      "settings": {
        "foreground": "#7E581B"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#7E581B",
    "type": "#7E581B",
    "class": "#7E581B",
    "enum": "#7E581B",
    "interface": "#7E581B",
    "struct": "#7E581B",
    "typeParameter": "#2A7352",
    "parameter": "#42516A",
    "variable": "#42516A",
    "property": "#42516A",
    "enumMember": "#5E6A32",
    "event": "#557741",
    "function": "#557741",
    "method": "#557741",
    "macro": "#557741",
    "keyword": "#6C6200",
    "comment": "#665A36",
    "string": "#5E6A32",
    "number": "#5E6A32",
    "regexp": "#2A7352",
    "operator": "#2F2B26",
    "decorator": "#2A7352",
    "newOperator": "#6C6200",
    "stringLiteral": "#5E6A32",
    "customLiteral": "#5E6A32",
    "numberLiteral": "#5E6A32"
  }
}
